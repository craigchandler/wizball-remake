FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Ubuntu main mirrors only carry amd64/i386.
# armhf packages live on ports.ubuntu.com -- pin each arch to the right source.
RUN dpkg --add-architecture armhf \
 && printf 'deb [arch=amd64,i386] http://archive.ubuntu.com/ubuntu jammy main restricted universe multiverse\ndeb [arch=amd64,i386] http://archive.ubuntu.com/ubuntu jammy-updates main restricted universe multiverse\ndeb [arch=amd64,i386] http://archive.ubuntu.com/ubuntu jammy-backports main restricted universe multiverse\ndeb [arch=amd64,i386] http://security.ubuntu.com/ubuntu jammy-security main restricted universe multiverse\ndeb [arch=armhf] http://ports.ubuntu.com/ubuntu-ports jammy main restricted universe multiverse\ndeb [arch=armhf] http://ports.ubuntu.com/ubuntu-ports jammy-updates main restricted universe multiverse\ndeb [arch=armhf] http://ports.ubuntu.com/ubuntu-ports jammy-backports main restricted universe multiverse\ndeb [arch=armhf] http://ports.ubuntu.com/ubuntu-ports jammy-security main restricted universe multiverse\n' > /etc/apt/sources.list \
 && apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    pkg-config \
    crossbuild-essential-armhf \
    libsdl2-dev:armhf \
    libsdl2-mixer-dev:armhf \
    libsdl2-image-dev:armhf \
    libgles2-mesa-dev:armhf \
 && rm -rf /var/lib/apt/lists/*

# CMake toolchain file for armhf cross-compilation
RUN printf 'set(CMAKE_SYSTEM_NAME Linux)\nset(CMAKE_SYSTEM_PROCESSOR armv7l)\nset(CMAKE_C_COMPILER arm-linux-gnueabihf-gcc)\nset(CMAKE_CXX_COMPILER arm-linux-gnueabihf-g++)\nset(CMAKE_FIND_ROOT_PATH /usr/arm-linux-gnueabihf)\nset(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)\nset(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)\nset(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)\nset(PKG_CONFIG_EXECUTABLE arm-linux-gnueabihf-pkg-config)\n' > /toolchain-armhf.cmake

WORKDIR /workspace
